#!/bin/sh /etc/rc.common
USE_PROCD=1
START=99
STOP=10

start_service() {
    local wan_ip tries=0
    while [ $tries -lt 30 ]; do
        wan_ip=$(ip route get 1.1.1.1 2>/dev/null | awk '/src/{print $7}')
        [ -n "$wan_ip" ] && break
        sleep 2
        tries=$((tries+1))
    done
    [ -z "$wan_ip" ] && return 1

    procd_open_instance
    procd_set_param command /usr/bin/frpc -c /etc/frp/frpc.ini
    procd_set_param respawn 3600 5 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

stop_service() { killall -q frpc 2>/dev/null || true; }
