#!/bin/sh

# ── IPv6 отключить ──────────────────────────────
uci set network.wan.ipv6='0'
uci set network.wan6.disabled='1'
uci commit network

# Отключить IPv6 сервисы
/etc/init.d/odhcpd disable 2>/dev/null
/etc/init.d/odhcpd stop 2>/dev/null

# ── SSH — закрыть с WAN через firewall ──────────
# FRP продолжает работать (outbound соединение, не затрагивается)
uci add firewall rule > /dev/null
uci set firewall.@rule[-1].name='Block-SSH-WAN'
uci set firewall.@rule[-1].src='wan'
uci set firewall.@rule[-1].dest_port='22'
uci set firewall.@rule[-1].proto='tcp'
uci set firewall.@rule[-1].target='DROP'
uci commit firewall

# ── Flow offloading ─────────────────────────────
uci set firewall.@defaults[0].flow_offloading='1'
uci set firewall.@defaults[0].flow_offloading_hw='1'
uci commit firewall

# ── zram — настройка под объём RAM ─────────────
MEM_KB=$(awk '/MemTotal/{print $2}' /proc/meminfo)
if [ "$MEM_KB" -gt 450000 ]; then
    ZRAM_MB=256
elif [ "$MEM_KB" -gt 200000 ]; then
    ZRAM_MB=128
else
    ZRAM_MB=64
fi

# zram-swap конфиг
uci -q delete system.zram_swap 2>/dev/null
uci set system.zram_swap=zram
uci set system.zram_swap.enabled='1'
uci set system.zram_swap.zram_size_mb="$ZRAM_MB"
uci commit system

logger -t system_tweaks "Applied: IPv6 off, SSH WAN blocked, flow offload on, zram=${ZRAM_MB}MB"

exit 0
